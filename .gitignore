# ══════════════════════════════════════════════════════════════════
#  mizannnnew — .gitignore
# ══════════════════════════════════════════════════════════════════

# ── Python bytecode (créé par python -m py_compile / Règle 3) ──
__pycache__/
*.pyc
*.pyo
*.pyd

# ── OS ──
.DS_Store
Thumbs.db

# ── Editors ──
.vscode/
.idea/
*.swp
*~

# ── Databases (GitHub 100 MB limit) ──
*.db
*.sqlite
*.sqlite3
backend/mizan.db
backend/almizane.db
backups/
"*.db"

# ── Secrets (clés API, tokens) ──
.env.local
.env.*.local

# ── Fichiers générés ou temporaires ──
audit_*.py
audit_*.json
audit_*.md
RAPPORT_*.md
check_*.py
clean_*.py
*.log
backend/corpus/
backend_server.log