# Al-Mīzān v5.0 — Configuration

# Clé API Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# CORS : origines autorisées (séparées par virgule)
# Dev: http://localhost:8000
# Prod: https://al-mizan.app,https://www.al-mizan.app
MIZAN_ALLOWED_ORIGINS=http://localhost:8000

# Mode de développement
DEBUG=true

# Port du serveur (optionnel, défaut: 8000)
PORT=8000