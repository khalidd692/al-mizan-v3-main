# =============================================================
# Al-Mīzān V5.0 — Configuration (copier vers .env)
# =============================================================

# Mode démo : false = vraie base de données, true = fixtures mockées
MOCK_MODE=false

# Base de données SQLite
# Choisir l'un des fichiers présents dans backend/
DATABASE_URL=sqlite:///backend/mizan.db
# DATABASE_URL=sqlite:///backend/almizane.db
# DATABASE_URL=sqlite:///backend/database/almizan_v7.db

# Clé API (décommenter si les agents appellent l'API)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
