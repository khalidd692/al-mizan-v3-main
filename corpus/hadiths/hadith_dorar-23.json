  "zone_03": {
    "term_ar": "الحسن",
    "term_fr": "Ḥasan",
    "transliteration": "ḥasan",
    "category": "degré",
    "definition_fr": "Caractère de ce qui est rapporté par une chaîne ininterrompue, par un transmetteur de confiance dont la mémoire est légèrement déficiente, et qui est exempt de défaut et de contradiction.",
    "source": "mustalah_definitions_fr.json"
  },
  "zone_04": {
    "text_fr": "Rapporté par Abu Said Al-Khudri : Le Messager d'Allah (ﷺ) a dit : Pendant que je dormais, j'ai vu (en rêve) des gens portant des chemises, certaines arrivaient à la poitrine, d'autres étaient encore plus courtes. Umar bin Al-Khattab m'est apparu portant une chemise qu'il traînait derrière lui. Les gens ont demandé : Comment l'as-tu interprété, ô Messager d'Allah (ﷺ) ? Il (le Prophète (ﷺ)) a répondu : C'est la religion",
    "source": "db_locale"
  },
