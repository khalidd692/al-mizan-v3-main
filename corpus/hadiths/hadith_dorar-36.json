  "zone_03": {
    "term_ar": "الحسن",
    "term_fr": "Ḥasan",
    "transliteration": "ḥasan",
    "category": "degré",
    "definition_fr": "Caractère de ce qui est rapporté par une chaîne ininterrompue, par un transmetteur de confiance dont la mémoire est légèrement déficiente, et qui est exempt de défaut et de contradiction.",
    "source": "mustalah_definitions_fr.json"
  },
  "zone_04": {
    "text_fr": "Rapporté par Abu Huraira : Le Prophète (ﷺ) a dit : Celui qui participe à un combat dans la cause d'Allah et n'est poussé à le faire que par sa foi en Allah et en Son Messager, Allah le récompensera soit par une récompense, soit par un butin (s'il survit), soit il sera admis au Paradis (s'il meurt en martyr). Si cela n'était pas difficile pour mes fidèles, je n'aurais jamais manqué d'accompagner une expédition partant pour le jihad, et j'aurais aimé être tué en martyr dans la cause d'Allah, puis ressuscité, puis tué à nouveau en martyr, puis ressuscité, et encore tué en martyr pour Lui",
    "source": "db_locale"
  },
