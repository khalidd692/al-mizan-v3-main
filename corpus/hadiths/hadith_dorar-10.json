  "zone_03": {
    "term_ar": "الصحيح",
    "term_fr": "Ṣaḥīḥ",
    "transliteration": "ṣaḥīḥ",
    "category": "degré",
    "definition_fr": "Caractère de ce qui est rapporté par une chaîne ininterrompue, par un transmetteur de confiance (ʿadl) dont la mémoire est fiable (ḍābiṭ tām), et qui est exempt de défaut (ʿilla) et de contradiction (shudhūdh) avec un groupe de rapporteurs de confiance.",
    "source": "mustalah_definitions_fr.json"
  },
  "zone_04": {
    "text_fr": "Rapporté par 'Abdullah bin 'Amr : Le Prophète (ﷺ) a dit : Un musulman est celui qui ne fait de mal à aucun autre musulman, ni par ses paroles ni par ses actes. Et un Muhajir (émigrant) est celui qui abandonne tout ce qu'Allah a interdit",
    "source": "db_locale"
  },
