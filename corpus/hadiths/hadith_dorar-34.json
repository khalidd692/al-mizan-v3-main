  "zone_01": {
    "text_ar": "1 -  «أوتيتُ مفاتيحَ كُلِّ شيءٍ إلَّا الخمسَ: {إِنَّ اللهَ عِندَه عِلمُ السَّاعةِ}\n[لقمان34] الآية  .",
    "source": "dorar"
  },
  "zone_02": {
    "grade": "Sahih",
