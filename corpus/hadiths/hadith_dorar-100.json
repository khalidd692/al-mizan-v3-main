  "zone_03": {
    "term_ar": "الصحيح",
    "term_fr": "Ṣaḥīḥ",
    "transliteration": "ṣaḥīḥ",
    "category": "degré",
    "definition_fr": "Caractère de ce qui est rapporté par une chaîne ininterrompue, par un transmetteur de confiance (ʿadl) dont la mémoire est fiable (ḍābiṭ tām), et qui est exempt de défaut (ʿilla) et de contradiction (shudhūdh) avec un groupe de rapporteurs de confiance.",
    "source": "mustalah_definitions_fr.json"
  },
  "zone_04": {
    "text_fr": "Rapporté par `Abdullah bin `Amr bin Al-`As : J’ai entendu le Messager d’Allah (ﷺ) dire : « Allah ne retire pas la science en l’enlevant des cœurs des gens, mais Il la retire en faisant mourir les savants religieux. Quand il n’en restera plus, les gens prendront pour chefs des ignorants qui, consultés, donneront des avis sans connaissance. Ils s’égareront et égareront les autres. »",
    "source": "db_locale"
  },
