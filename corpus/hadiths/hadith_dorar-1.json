  "zone_03": {
    "term_ar": "الصحيح",
    "term_fr": "Ṣaḥīḥ",
    "transliteration": "ṣaḥīḥ",
    "category": "degré",
    "definition_fr": "Caractère de ce qui est rapporté par une chaîne ininterrompue, par un transmetteur de confiance (ʿadl) dont la mémoire est fiable (ḍābiṭ tām), et qui est exempt de défaut (ʿilla) et de contradiction (shudhūdh) avec un groupe de rapporteurs de confiance.",
    "source": "mustalah_definitions_fr.json"
  },
  "zone_04": {
    "text_fr": "Rapporté par 'Umar ibn Al-Khattab : J'ai entendu le Messager d'Allah (ﷺ) dire : « La récompense des actions dépend des intentions, et chacun sera récompensé selon son intention. Donc, celui qui a émigré pour obtenir des biens matériels ou pour épouser une femme, son émigration sera pour ce pour quoi il a émigré. »",
    "source": "db_locale"
  },
