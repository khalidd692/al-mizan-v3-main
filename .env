# Al-Mīzān V5.0 — Configuration locale
# Ce fichier ne contient pas de secrets — les clés API vont dans .env.local

# Mode démo : false = vraie base de données, true = fixtures mockées
MOCK_MODE=false

# Base de données SQLite principale (351 MB, 122k hadiths)
DATABASE_URL=sqlite:///backend/mizan.db

# Alternatives disponibles :
# DATABASE_URL=sqlite:///backend/almizane.db
# DATABASE_URL=sqlite:///backend/database/almizan_v7.db

# Clés API → mettre dans .env.local (gitignored)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
