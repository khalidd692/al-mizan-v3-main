# Al-Mizan V7.0 - Context optimization for AI agents
# Goal: cut token usage while keeping business logic visible.

# =========================
# Exclude technical noise
# =========================

# VCS and environments
.git/
.venv/
**/.venv/
**/node_modules/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.vscode/

# Python/JS build artifacts
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dylib
*.dll
*.class
*.o
*.obj

# Logs, temp, backups, dumps
logs/
backups/
output/
tmp/
temp/
cache/
**/*.log
**/*.tmp
**/*.bak
**/*.dump
**/*.pid
**/*.swp
**/*.swo

# Databases and heavy binaries
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.parquet
*.feather
*.arrow
*.bin

# Project-specific heavy/derived folders
backend/cache/
backend/temp/
backend/logs/
backend/corpus/**/.git/

# =========================
# Keep critical context visible
# =========================

# AI rules and docs
!.clauderules
!**/*.md
!**/*.mdc
!**/*.rules

# Business data and config (structured text)
!**/*.json
!**/*.yaml
!**/*.yml
!**/*.toml
!**/*.ini
!**/*.cfg
!**/*.conf
!**/*.sql
!**/*.csv
!**/*.tsv

# Explicitly keep critical domain files
!backend/data/
!backend/data/salafi_authorities.json
!backend/fixtures/
!backend/migrations/
!backend/connectors/
!backend/api/
!tests/

# Extra explicit allowlist (anti-blindness audit)
!backend/agents/
!backend/agents/prompts/
!backend/agents/prompts/*.md
!api/demo_responses.json
!backend/fixtures/demo_responses.json
!frontend/timeline-demo.html

# Phase 2: evolving allowlist for domain knowledge
!backend/database/
!backend/database/*.sql
!backend/init*_schema*.sql
!backend/corpus/schema.sql
!backend/migrations/*.sql
!backend/omniroute_naqil_chain_combo.json
